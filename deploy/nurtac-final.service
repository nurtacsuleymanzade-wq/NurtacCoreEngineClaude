[Unit]
Description=NurtacCoreEngineClaude Layer-15 Final Setup Engine
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/NurtacCoreEngineClaude
ExecStartPre=/bin/sleep 65
ExecStart=/root/NurtacCoreEngineClaude/.venv/bin/python3 final_setup_engine.py --mode live
Restart=always
RestartSec=5
MemoryMax=400M
MemorySwapMax=200M

[Install]
WantedBy=multi-user.target
