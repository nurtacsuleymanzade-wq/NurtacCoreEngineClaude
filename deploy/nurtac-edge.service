[Unit]
Description=NurtacCoreEngineClaude Layer-14 Edge Matrix Engine
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/NurtacCoreEngineClaude
ExecStart=/root/NurtacCoreEngineClaude/.venv/bin/python3 edge_matrix_engine.py --mode live
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
