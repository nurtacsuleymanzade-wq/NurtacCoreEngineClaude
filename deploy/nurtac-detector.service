[Unit]
Description=NurtacCoreEngineClaude Layer-4 Detector Engine
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/NurtacCoreEngineClaude
ExecStartPre=/bin/sleep 5
ExecStart=/root/NurtacCoreEngineClaude/.venv/bin/python3 detector_engine.py --mode live
Restart=always
RestartSec=5
MemoryMax=400M
MemorySwapMax=200M

[Install]
WantedBy=multi-user.target
