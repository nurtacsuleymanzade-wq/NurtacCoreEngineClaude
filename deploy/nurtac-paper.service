[Unit]
Description=NurtacCoreEngineClaude Layer-12 Paper Trade Engine
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/NurtacCoreEngineClaude
ExecStart=/root/NurtacCoreEngineClaude/.venv/bin/python3 paper_trade_engine.py --mode live
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
